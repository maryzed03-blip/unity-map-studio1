rules_version = '2';
// Firestore security rules for Unity Map Studio.
// Data model lives in src/lib/projects.ts, src/lib/live-sessions.ts,
// and src/lib/auth-context.tsx. Keep these rules in sync with that code.
//
// Roles are stored on users/{uid}.role — `student | teacher | therapist`.
// Role is set at signup and MUST NOT be changed by the user afterwards
// (a separate trusted path / admin tool must mutate it).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── users/{uid} ───────────────────────────────────────────────
    // Any signed-in user can read profiles (needed to display names /
    // roles in live sessions and invitations). Only the owner can
    // write, and the `role` field is immutable after creation.
    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSelf(uid)
        && request.resource.data.uid == uid;

      allow update: if isSelf(uid)
        && (!('role' in request.resource.data)
            || request.resource.data.role == resource.data.role);

      allow delete: if false;

      // Per-user private subcollection (e.g. OpenAI API key).
      // ONLY the owning user can read or write — no one else.
      match /private/{docId} {
        allow read, write: if isSelf(uid);
      }
    }

    // ── projects/{projectId} ─────────────────────────────────────
    function projectDoc(pid) {
      return get(/databases/$(database)/documents/projects/$(pid)).data;
    }
    function isProjectOwner(pid) {
      return isSignedIn() && projectDoc(pid).ownerId == request.auth.uid;
    }
    function isProjectMember(pid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/projects/$(pid)/members/$(request.auth.uid));
    }
    // A live-session board (main lesson board OR a group board — both get
    // `liveSessionId` set at creation, see live-sessions.ts) is readable
    // and writable by anyone actually in that session right now, not just
    // its owner. Nothing in the app ever populates the members/
    // subcollection for students, so without this, isProjectMember() above
    // is always false for them and live boards were unreadable/unwritable
    // by any student — this is what silently broke live sync.
    function isLiveSessionPeer(pid) {
      return isSignedIn()
        && ("liveSessionId" in projectDoc(pid))
        && projectDoc(pid).liveSessionId != null
        && (
          get(/databases/$(database)/documents/liveSessions/$(projectDoc(pid).liveSessionId)).data.teacherId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/liveSessions/$(projectDoc(pid).liveSessionId)).data.participantIds
        );
    }
    // End-of-lesson personal-copy distribution (see endSessionAndSave in
    // live-sessions.ts): the TEACHER's browser creates one project per
    // contributing student, owned by that student, not the teacher. That
    // would normally fail create's "ownerId == request.auth.uid" check —
    // this is a narrow, self-contained exception: only lets it through
    // when the new doc's own sourceSessionId proves (via a fresh get())
    // that the caller really is that exact session's teacher AND the
    // target ownerId really is a participant of that exact session.
    // Nothing else about the new doc is trusted or exempted.
    function isDistributingToParticipant() {
      return isSignedIn()
        && ("sourceSessionId" in request.resource.data)
        && request.resource.data.sourceSessionId is string
        && get(/databases/$(database)/documents/liveSessions/$(request.resource.data.sourceSessionId)).data.teacherId == request.auth.uid
        && request.resource.data.ownerId
             in get(/databases/$(database)/documents/liveSessions/$(request.resource.data.sourceSessionId)).data.participantIds;
    }
    // Same idea for that copy's own snapshot doc, read off the ALREADY
    // created parent project (so it must have sourceSessionId set by the
    // create above, which only the exception just above could achieve).
    function isDistributedCopySnapshot(pid) {
      return isSignedIn()
        && ("sourceSessionId" in projectDoc(pid))
        && projectDoc(pid).sourceSessionId != null
        && get(/databases/$(database)/documents/liveSessions/$(projectDoc(pid).sourceSessionId)).data.teacherId == request.auth.uid
        && projectDoc(pid).ownerId
             in get(/databases/$(database)/documents/liveSessions/$(projectDoc(pid).sourceSessionId)).data.participantIds;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn()
        && (resource.data.ownerId == request.auth.uid || isProjectMember(projectId) || isLiveSessionPeer(projectId));

      allow create: if isSignedIn()
        && (request.resource.data.ownerId == request.auth.uid || isDistributingToParticipant());

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      // ── members subcollection ──
      // Only the project owner manages membership. A member may read
      // (not write) their own membership doc.
      match /members/{memberUid} {
        allow read: if isSignedIn()
          && (isProjectOwner(projectId) || request.auth.uid == memberUid);
        allow write: if isProjectOwner(projectId);
      }

      // ── snapshots subcollection ──
      match /snapshots/{snapshotId} {
        allow read, write: if isProjectOwner(projectId) || isProjectMember(projectId) || isLiveSessionPeer(projectId) || isDistributedCopySnapshot(projectId);
      }
    }

    // ── liveSessions/{sessionId} ─────────────────────────────────
    function sessionDoc(sid) {
      return get(/databases/$(database)/documents/liveSessions/$(sid)).data;
    }
    function isSessionTeacher(sid) {
      return isSignedIn() && sessionDoc(sid).teacherId == request.auth.uid;
    }
    function isSessionParticipant(sid) {
      return isSignedIn()
        && request.auth.uid in sessionDoc(sid).participantIds;
    }

    match /liveSessions/{sessionId} {
      allow read: if isSignedIn()
        && (resource.data.teacherId == request.auth.uid
            || request.auth.uid in resource.data.participantIds);

      allow create: if isSignedIn()
        && request.resource.data.teacherId == request.auth.uid;

      // Teacher has full write. Otherwise, an existing participant
      // accepting an invitation may append themselves to participantIds
      // (and change nothing else).
      allow update: if isSignedIn() && (
        resource.data.teacherId == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['participantIds'])
          && request.resource.data.participantIds.hasAll(resource.data.participantIds)
          && (request.resource.data.participantIds.toSet()
                .difference(resource.data.participantIds.toSet()))
                == [request.auth.uid].toSet()
        )
      );

      allow delete: if isSignedIn()
        && resource.data.teacherId == request.auth.uid;

      // ── groupRooms subcollection ──
      match /groupRooms/{roomId} {
        allow read: if isSessionTeacher(sessionId) || isSessionParticipant(sessionId);

        // Teacher: full control (create/delete groups, assign/move anyone).
        // A session participant may also write, but ONLY a change that adds
        // or removes exactly themselves from participantIds — covers the
        // student-facing "Είσοδος" (join) / "Έξοδος" (leave) buttons.
        allow write: if isSessionTeacher(sessionId)
          || (
            isSessionParticipant(sessionId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantIds'])
            && request.resource.data.participantIds.toSet()
                 .difference(resource.data.participantIds.toSet())
                 .union(
                   resource.data.participantIds.toSet()
                     .difference(request.resource.data.participantIds.toSet())
                 )
               == [request.auth.uid].toSet()
          );

        // ── members subcollection — per-student join/leave/contribution
        // history (see recordGroupJoin/Leave/markGroupContribution in
        // live-sessions.ts). Written entirely by each student's OWN
        // browser about THEIR OWN record — never on behalf of anyone
        // else. The teacher reads this (not writes) to decide who
        // actually contributed when distributing final copies.
        match /members/{memberUid} {
          allow read: if isSessionTeacher(sessionId) || isSessionParticipant(sessionId);
          allow write: if isSelf(memberUid) && isSessionParticipant(sessionId);
        }
      }
    }

    // ── workspaceRooms/{roomId} ───────────────────────────────────
    // Public, standalone co-working spaces (data model in
    // src/lib/workspaces-rooms.ts). Anyone signed in can see and enter/leave
    // them; only the mutable occupancy/token fields may change on update —
    // structural fields (name, boardId) are fixed after bootstrap.
    function userRole() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isTeacherOrTherapist() {
      return userRole() == 'teacher' || userRole() == 'therapist';
    }

    match /workspaceRooms/{roomId} {
      allow read: if isSignedIn();

      // Bootstrap only — creates the fixed set of room docs once.
      allow create: if isTeacherOrTherapist();

      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'occupants', 'teacherOccupants', 'occupantNames',
               'tokenHolder', 'tokenRequesterId', 'tokenRequesterName',
               'tokenRequestedAt', 'lastActivityAt', 'sessionParticipants',
               'activeSessionId',
             ]);

      allow delete: if false;
    }

    // ── receivedDesigns/{designId} ────────────────────────────────
    // "Στείλε το σχέδιο" — a one-way copy notification. Only the two
    // parties involved can see it; only the recipient may flip its status.
    match /receivedDesigns/{designId} {
      allow read: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      allow delete: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
    }

    // ── invitations/{invitationId} ───────────────────────────────
    // Only the two parties can see an invitation. The recipient may
    // only flip its `status` field; the sender controls everything else.
    match /invitations/{invitationId} {
      allow read: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid;

      allow update: if isSignedIn() && (
        resource.data.fromUserId == request.auth.uid
        || (
          resource.data.toUserId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status'])
        )
      );

      allow delete: if isSignedIn()
        && resource.data.fromUserId == request.auth.uid;
    }

    // ── folders/{folderId} ───────────────────────────────────────
    // Stage 6: personal/private project folders. No sharing semantics.
    // Owner-only read/write, mirroring the projects ownership pattern.
    match /folders/{folderId} {
      allow read: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;

      allow delete: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }
  }
}
